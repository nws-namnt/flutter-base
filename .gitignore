# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# Flutter DevTools (IDE-generated, personal config)
devtools_options.yaml

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Flutter plugins
.flutter-plugins

# Firebase config (sensitive — generated by flutterfire configure)
google-services.json
GoogleService-Info.plist

# build_runner generated files
*.g.dart
*.freezed.dart
*.mocks.dart

# intl_utils generated files
lib/generated/

# Environment files — real values must NOT be committed
# Commit only the .example templates, not the real .env files
assets/env/.env.dev
assets/env/.env.uat
assets/env/.env.prod
