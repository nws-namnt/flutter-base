# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# Flutter DevTools (IDE-generated, personal config)
devtools_options.yaml

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
!doc/api/
!pkgs/dart_cli/doc/api/

**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Flutter plugins
.flutter-plugins

# Firebase config (sensitive — generated by flutterfire configure)
google-services.json
GoogleService-Info.plist

# build_runner generated files
*.g.dart
*.freezed.dart
*.mocks.dart

# Pigeon-generated Dart output — commit alongside native generated files so the repo
# builds without requiring `dart run pigeon` after a fresh clone.
!lib/generated/pigeon_api.g.dart

# intl_utils / flutter_gen output — list files explicitly so the pigeon exception above works
# (git cannot un-ignore a file inside an excluded directory)
lib/generated/l10n.dart
lib/generated/intl/
lib/generated/assets.dart
lib/generated/app_assets.dart

# Environment files — real values must NOT be committed
# Commit only the .example templates, not the real .env files
assets/env/.env.dev
assets/env/.env.uat
assets/env/.env.prod

# CLI personal config override (team default fx_config.yaml is committed)
cli_config.yaml

# Claude Cowork session data
.claude/

# CocoaPods — not used when project is on Swift Package Manager
ios/Podfile
ios/Podfile.lock
ios/Pods/