<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required for all network calls (Dio, Firebase, connectivity check).
         Must be in the main manifest — debug/profile manifests are not merged into release builds. -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Required to check network interface state (used by connectivity_plus).
         The plugin auto-merges this, but declared here for clarity. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- ───── CAMERA ─────
         Required to capture photos/videos via image_picker (ImageSource.camera).
         Not needed if only picking from gallery. -->
    <uses-permission android:name="android.permission.CAMERA"/>

    <!-- Declares that the app uses camera hardware but does not require it.
         android:required="false" means the app can still be installed on devices
         without a camera (e.g. some tablets) — camera features will simply be unavailable.
         Without this tag, Google Play assumes required="true" and filters out camera-less devices. -->
    <uses-feature android:name="android.hardware.camera" android:required="false"/>

    <!-- ───── STORAGE — legacy (API 28 and below) ─────
         READ_EXTERNAL_STORAGE: read files from shared storage (images, video, audio, documents).
           Effective on API 32 and below. On API 33+, scoped media permissions replace it —
           but since we use Android Photo Picker and SAF, READ_EXTERNAL_STORAGE is only needed
           for devices on API 32- that access files outside a system picker.
           maxSdkVersion="32" prevents the permission from being requested on API 33+.

         WRITE_EXTERNAL_STORAGE: write files to shared storage.
           Effective only on API 28 and below — on API 29+ it is silently ignored by the OS
           regardless of whether it is declared (scoped storage disallows broad write access).
           maxSdkVersion="28" makes the intent explicit and suppresses the lint warning. -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"/>

    <!-- ───── MEDIA — granular (API 33+) ─────
         Replaces READ_EXTERNAL_STORAGE for each media type on Android 13+.
         Each permission is independent — request only what the app actually needs. -->

    <!-- READ_MEDIA_IMAGES and READ_MEDIA_VIDEO are intentionally omitted.
         Google Play's Photo & Video Permissions policy (enforced May 2025) rejects apps
         that declare these unless they have an approved core use case requiring broad library access.
         image_picker uses the Android Photo Picker internally (no permission needed).
         file_picker uses SAF (Storage Access Framework) — also no permission needed. -->

    <!-- READ_MEDIA_AUDIO: file_picker uses SAF for audio files, so this is also not required.
         Declare only if the app reads audio files programmatically outside a system picker. -->
    <!-- <uses-permission android:name="android.permission.READ_MEDIA_AUDIO"/> -->

    <!-- ───── MEDIA LOCATION ─────
         Required on API 29+ to read GPS/EXIF location metadata from photos/videos.
         Without this, location tags are stripped from media even if READ_MEDIA_IMAGES is granted. -->
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION"/>

    <!-- Required to show notifications on Android 13+ (API 33+).
         Ignored automatically on API < 33 — no maxSdkVersion needed.
         Runtime permission: must also be requested via firebase_messaging.requestPermission()
         or flutter_local_notifications.requestNotificationsPermission(). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Required to vibrate the device when a notification is displayed.
         Used by the default notification channel (enableVibration: true in NotificationService). -->
    <uses-permission android:name="android.permission.VIBRATE"/>

    <!-- Required to deliver BOOT_COMPLETED broadcast to ScheduledNotificationBootReceiver.
         Without this permission, the receiver is registered but never invoked after reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- Required to schedule exact-time alarms on Android 12+ (API 31+).
         Covers all API levels — no maxSdkVersion set intentionally.
         On API 31–32: granted at install time, not user-revocable.
         On API 33+: user can revoke via Settings → Apps → Special app access → Alarms & reminders;
           app must handle the revoked case (check canScheduleExactAlarms() before scheduling).
         USE_EXACT_ALARM is intentionally omitted — it is restricted by Google Play to alarm clock
         and calendar app categories only and would require policy justification. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>

    <!-- showWhenLocked: display the activity over the lock screen without requiring unlock.
     Requires API 27+. On API 24–26 (minSdk), this attribute is silently ignored —
     use Window.FLAG_SHOW_WHEN_LOCKED programmatically for those versions if needed.
     tools:targetApi="27" suppresses the lint warning without raising minSdkVersion. -->
    <!-- turnScreenOn: turn on the screen when the activity starts (e.g. incoming call/alarm).
     Requires API 27+. Same limitation as showWhenLocked on API 24–26. -->

    <application
        android:label="flutter_base"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            tools:targetApi="27">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- FCM: overrides the default notification channel used when a data-only message
             arrives while the app is in the background/killed. Must match
             AppConstants.kAndroidChannelId so all FCM notifications land in the correct channel. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="fox_channel"/>

        <!-- Do not delete — used by the Flutter tool to generate GeneratedPluginRegistrant.java. -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- flutter_local_notifications: receives the broadcast fired by AlarmManager when a
             scheduled/periodic notification is due. Required for exact-alarm scheduling to work
             while the app is in background or killed. -->
        <receiver
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver"
            android:exported="false"/>

        <!-- flutter_local_notifications: re-registers all scheduled/periodic notifications after
             the device reboots (exact alarms are cleared on reboot).
             Requires RECEIVE_BOOT_COMPLETED permission.
             QUICKBOOT_POWERON covers HTC / some OEM fast-boot sequences. -->
        <receiver
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON"/>
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>

        <!-- Disable Impeller rendering engine on Android.
             Impeller is Flutter's newer rendering backend — disabled here due to known visual
             artifacts on certain GPU drivers. Re-enable once stable for your target device range. -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- url_launcher: required on Android 11+ (API 30+) to resolve a browser app for https/http.
             The BROWSABLE category is mandatory — without it canLaunchUrl() returns false because
             the system does not match the intent to a browser, even if one is installed. -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <category android:name="android.intent.category.BROWSABLE"/>
            <data android:scheme="https"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <category android:name="android.intent.category.BROWSABLE"/>
            <data android:scheme="http"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO"/>
            <data android:scheme="mailto"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL"/>
            <data android:scheme="tel"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO"/>
            <data android:scheme="sms"/>
        </intent>
    </queries>
</manifest>
